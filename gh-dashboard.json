    {
        "id": "0331b7e8018058e8",
        "type": "function",
        "z": "6cda5a5f32196c63",
        "name": "Parse sensor line (JSON or key=val)",
        "func": "function parseKeyVal(line){\n    var o = {};\n    var parts = line.split(',');\n    for(var i=0;i<parts.length;i++){\n        var p = parts[i].trim();\n        if(!p) continue;\n        var kv = p.split('=');\n        if(kv.length !== 2) continue;\n        var k = kv[0].trim();\n        var v = kv[1].trim();\n        var n = Number(v);\n        o[k] = isNaN(n) ? v : n;\n    }\n    return o;\n}\n\nvar s = (msg.payload || \"\").toString().trim();\nif(!s){ return null; }\n\nvar data = null;\n\n// Try JSON first\nif(s[0] === '{'){\n    try {\n        data = JSON.parse(s);\n    } catch(e) {\n        data = null;\n    }\n}\n\n// Fallback: key=val list\nif(!data){\n    data = parseKeyVal(s);\n}\n\n// Normalize names (accept either t1/T1, etc.)\nfunction pick(obj, keys){\n    for(var i=0;i<keys.length;i++){\n        if(obj.hasOwnProperty(keys[i])) return obj[keys[i]];\n    }\n    return undefined;\n}\n\nvar t1 = pick(data, ['t1','T1','temp1','Temp1']);\nvar t2 = pick(data, ['t2','T2','temp2','Temp2']);\nvar h1 = pick(data, ['h1','H1','hum1','Hum1']);\nvar h2 = pick(data, ['h2','H2','hum2','Hum2']);\nvar soil = pick(data, ['soil','SOIL','sm','SM']);\nvar lux = pick(data, ['lux','LUX','light','LIGHT']);\n\n// Compute averages if both exist\nvar tavg = (typeof t1 === 'number' && typeof t2 === 'number') ? (t1+t2)/2 : (typeof t1 === 'number' ? t1 : (typeof t2 === 'number' ? t2 : undefined));\nvar havg = (typeof h1 === 'number' && typeof h2 === 'number') ? (h1+h2)/2 : (typeof h1 === 'number' ? h1 : (typeof h2 === 'number' ? h2 : undefined));\n\nvar out = {\n    ts: Date.now(),\n    t1: t1,\n    t2: t2,\n    tavg: tavg,\n    h1: h1,\n    h2: h2,\n    havg: havg,\n    soil: soil,\n    lux: lux\n};\n\nflow.set('gh_last', out);\nmsg.payload = out;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 420,
        "y": 120,
        "wires": [
            [
                "f98d2f1f0673b101",
                "e945f40524447b30",
                "ee12a869e25d83bb",
                "4b266addf47812be",
                "3999dea12c82b1a6"
            ]
        ]
    },
    {
        "id": "f98d2f1f0673b101",
        "type": "function",
        "z": "6cda5a5f32196c63",
        "name": "Format CSV line",
        "func": "var p = msg.payload;\nvar d = new Date(p.ts);\nfunction f(x){ return (x === undefined || x === null) ? '' : x; }\nvar line = [\n    d.toISOString(),\n    f(p.t1),f(p.t2),f(p.tavg),\n    f(p.h1),f(p.h2),f(p.havg),\n    f(p.soil),f(p.lux)\n].join(',') + \"\\n\";\nmsg.payload = line;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 660,
        "y": 60,
        "wires": [
            [
                "887f4b565053691c"
            ]
        ]
    },
