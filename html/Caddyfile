:80 {
	# Logging helps a lot when debugging path/routing issues
	log {
		output file /var/log/caddy/greenhouse_access.log
		format console
	}

	# Compression for html/css/js/json/csv
	encode zstd gzip

	# Static dashboard root
	root * /home/pff/greenhouse/dashboard

	# Bare host -> main dashboard
	@root path /
	redir @root /index.html 302

	# Optional: normalize /nodered to /nodered/
	@nodered_no_slash path /nodered
	redir @nodered_no_slash /nodered/ 302

	# Node-RED editor/admin and anything under it
	@nodered path /nodered /nodered/*
	handle @nodered {
		reverse_proxy localhost:1880
	}

	# Greenhouse history CSV generated by Node-RED
	@history path /history.csv
	handle @history {
		reverse_proxy localhost:1880
	}

	# Greenhouse websocket endpoint
	@ws path /ws/greenhouse
	handle @ws {
		reverse_proxy localhost:1880
	}

	# Optional future Node-RED dashboard/ui/api style routes
	@nr_extra path /ui /ui/* /api /api/* /dashboard /dashboard/*
	handle @nr_extra {
		reverse_proxy localhost:1880
	}

	# Serve real static files from the greenhouse dashboard directory
	handle {
		file_server
	}
}
