        "func": "let state = msg.payload.louvre_state;\n\nif (state === \"open\") {\n    msg.payload = \"🟢 OPEN — Ventilating\";\n} else if (state === \"closed\") {\n    msg.payload = \"⚫ CLOSED — Sealed\";\n} else if (state === \"opening\") {\n    msg.payload = \"🟡 OPENING — Adjusting\";\n} else if (state === \"closing\") {\n    msg.payload = \"🟡 CLOSING — Adjusting\";\n} else {\n    msg.payload = \"⚪ UNKNOWN\";\n}\n\nreturn msg;",
