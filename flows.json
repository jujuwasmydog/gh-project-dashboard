        "func": "// Guard greenhouse payload\n// Purpose:\n// 1) Reject malformed payloads\n// 2) Hold last known good payload\n// 3) Prevent one bad lux/glitch sample from zeroing all gauges\n\nlet p = msg.payload;\nlet last = context.get(\"lastGood\") || null;\n\nfunction isNum(v) {\n    return typeof v === \"number\" && isFinite(v);\n}\n\n// Payload must be an object\nif (typeof p !== \"object\" || p === null) {\n    if (last) {\n        msg.payload = last;\n        return msg;\n    }\n    return null;\n}\n\n// Required numeric fields\nlet required = [\n    \"t1\", \"t2\", \"tavg\",\n    \"h1\", \"h2\", \"havg\",\n    \"soil\", \"lux\",\n    \"louvre_pct\", \"fan_pct\"\n];\n\nfor (let k of required) {\n    if (!isNum(p[k])) {\n        if (last) {\n            msg.payload = last;\n            return msg;\n        }\n        return null;\n    }\n}\n\n// Optional string/state field check\nif (typeof p.louvre_state !== \"string\") {\n    if (last) {\n        msg.payload = last;\n        return msg;\n    }\n    return null;\n}\n\n// Range checks\nif (p.t1 < -40 || p.t1 > 150) { msg.payload = last || p; return last ? msg : null; }\nif (p.t2 < -40 || p.t2 > 150) { msg.payload = last || p; return last ? msg : null; }\nif (p.tavg < -40 || p.tavg > 150) { msg.payload = last || p; return last ? msg : null; }\n\nif (p.h1 < 0 || p.h1 > 100) { msg.payload = last || p; return last ? msg : null; }\nif (p.h2 < 0 || p.h2 > 100) { msg.payload = last || p; return last ? msg : null; }\nif (p.havg < 0 || p.havg > 100) { msg.payload = last || p; return last ? msg : null; }\n\nif (p.soil < 0 || p.soil > 100) { msg.payload = last || p; return last ? msg : null; }\nif (p.lux < 0 || p.lux > 150000) { msg.payload = last || p; return last ? msg : null; }\n\nif (p.louvre_pct < 0 || p.louvre_pct > 100) { msg.payload = last || p; return last ? msg : null; }\nif (p.fan_pct < 0 || p.fan_pct > 100) { msg.payload = last || p; return last ? msg : null; }\n\n// Lux deglitch:\n// If lux suddenly drops to 0 from a normal reading, treat it as a glitch\nif (last && isNum(last.lux)) {\n    if (p.lux === 0 && last.lux > 5) {\n        msg.payload = last;\n        return msg;\n    }\n}\n\n// Save good payload\ncontext.set(\"lastGood\", p);\nreturn msg;",
