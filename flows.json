    {
        "id": "0331b7e8018058e8",
        "type": "function",
        "z": "6cda5a5f32196c63",
        "name": "Parse sensor line (JSON or key=val)",
        "func": "let line = msg.payload;\n\nif (Buffer.isBuffer(line)) {\n    line = line.toString();\n}\n\nline = String(line).trim();\n\nif (!line) return null;\n\n// Try JSON first\nif (line.startsWith(\"{\") && line.endsWith(\"}\")) {\n    try {\n        let obj = JSON.parse(line);\n\n        msg.payload = {\n            ts: obj.ts,\n            t1: obj.t1,\n            t2: obj.t2,\n            tavg: obj.tavg,\n            h1: obj.h1,\n            h2: obj.h2,\n            havg: obj.havg,\n            soil: obj.soil,\n            lux: obj.lux,\n            louvre_pct: obj.louvre_pct,\n            louvre_state: obj.louvre_state,\n            fan_pct: obj.fan_pct,\n            lightOn: obj.lightOn\n        };\n\n        return msg;\n    } catch (e) {\n        node.warn(\"JSON parse failed: \" + e.message);\n        return null;\n    }\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 180,
        "wires": [
            [
                "f98d2f1f0673b101",
                "ee12a869e25d83bb",
                "4b266addf47812be",
                "3999dea12c82b1a6",
                "57ce7260347bd8de"
            ]
        ]
    },
    {
        "id": "f98d2f1f0673b101",
        "type": "function",
        "z": "6cda5a5f32196c63",
        "name": "Format CSV line",
        "func": "var p = msg.payload || {};\n\nconst columns = [\"timestamp\",\"t1\",\"t2\",\"tavg\",\"h1\",\"h2\",\"havg\",\"soil\",\"lux\"];\n\nfunction missing(x) {\n    return x === undefined || x === null || x === \"\";\n}\n\n// Reject incomplete rows so you stop getting timestamp-only lines\nif (\n    missing(p.ts)   ||\n    missing(p.t1)   ||\n    missing(p.t2)   ||\n    missing(p.tavg) ||\n    missing(p.h1)   ||\n    missing(p.h2)   ||\n    missing(p.havg) ||\n    missing(p.soil) ||\n    missing(p.lux)\n) {\n    return null;\n}\n\nvar d = new Date(p.ts);\nif (isNaN(d.getTime())) {\n    return null;\n}\n\nvar line = [\n    d.toISOString(),\n    p.t1, p.t2, p.tavg,\n    p.h1, p.h2, p.havg,\n    p.soil, p.lux\n].join(\",\") + \"\\n\";\n\nmsg.payload = line;\nmsg.csv_header = columns.join(\",\") + \"\\n\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 820,
        "y": 120,
        "wires": [
            [
                "887f4b565053691c"
            ]
        ]
    },
